{
  "manifest_version": 3,
  "name": "StockMonk – AI Stock Intelligence",
  "short_name": "StockMonk",
  "version": "1.0.0",
  "description": "Real-time buy signals, Reddit sentiment, and earnings data for US, UK, Indian and European stocks — all in one click.",
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "StockMonk",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}